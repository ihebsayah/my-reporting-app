APP_NAME=PFE Reporting App
APP_ENV=development
APP_DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/reporting_app
LABEL_STUDIO_URL=http://localhost:8080
LABEL_STUDIO_API_KEY=change-me
LABEL_STUDIO_PROJECT_TITLE=Invoice Field Extraction
DEFAULT_LOCALE=en
DEFAULT_TIMEZONE=Africa/Tunis
LOG_LEVEL=INFO
AUTO_APPROVAL_THRESHOLD=0.90
REVIEW_MIN_THRESHOLD=0.70
REVIEW_MAX_THRESHOLD=0.89
NER_MODEL_OUTPUT_DIR=artifacts/models/ner
NER_TRAIN_ITERATIONS=20
NER_MODEL_PATH=artifacts/models/ner
FIELD_THRESHOLDS_JSON={"INVOICE_ID":{"auto":0.92,"review_min":0.72,"review_max":0.91},"INVOICE_DATE":{"auto":0.90,"review_min":0.70,"review_max":0.89},"TOTAL_AMOUNT":{"auto":0.95,"review_min":0.80,"review_max":0.94},"VENDOR_NAME":{"auto":0.88,"review_min":0.68,"review_max":0.87}}
